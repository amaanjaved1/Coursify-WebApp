# Copy to .env.local and fill in your own values. Never commit .env.local or real secrets.
# https://supabase.com/dashboard/project/_/settings/api
#
# ⚠️  Use the **Legacy** API Keys tab in Supabase (Project Settings > API).
#     Do NOT use the newer "Publishable / Secret" keys — they don't work with the database API.
#
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  →  "anon public"   (Legacy tab)
#   SUPABASE_SERVICE_KEY           →  "service_role"   (Legacy tab)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service role key — server-side routes only (uploads, /api/me/*). Keep off the client and out of Git.
SUPABASE_SERVICE_KEY=your_service_role_key

# Optional: Upstash Redis REST API (caching). Omit both to run without Redis (more Supabase reads).
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Optional: GitHub token for higher contributor API rate limits on the About page.
# GITHUB_TOKEN=github_pat_your_token

# Secret for the internal semester auto-bump endpoint called by GitHub Actions. (not needed for local development)
CRON_SECRET=your_cron_secret
